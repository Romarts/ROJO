datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id    Int     @id @default(autoincrement())
  nome  String
  email String  @unique
  cpf   String  @unique
  senha String
  role  String  @default("USER")
}

model Category {
  id       Int       @id @default(autoincrement())
  nome     String    @unique
  products Product[]
}

model Product {
  id          Int      @id @default(autoincrement())
  nome        String
  preco       Float
  descricao   String?
  categoryId  Int
  category    Category @relation(fields: [categoryId], references: [id])
}